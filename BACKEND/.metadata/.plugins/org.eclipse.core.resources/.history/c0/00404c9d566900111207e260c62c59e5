package com.smartpizza.orderservice.client;

import com.smartpizza.orderservice.dto.MenuPizzaResponse;
import io.github.resilience4j.circuitbreaker.annotation.CircuitBreaker;
import org.springframework.cloud.openfeign.FeignClient;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;

// Calling menu-service with help of Eureka
@FeignClient(name = "menu-service")
public interface MenuClient {

    @GetMapping("/api/menu/pizzas/{pizzaId}")
    @CircuitBreaker(name = "menuService", fallbackMethod = "getPizzaFallback")
    MenuPizzaResponse getPizzaById(@PathVariable Long pizzaId);

    default MenuPizzaResponse getPizzaFallback(Long pizzaId, Throwable throwable) {
        MenuPizzaResponse response = new MenuPizzaResponse();
        response.setPizzaId(pizzaId);
        response.setPizzaName("Default Pizza");
        response.setDescription("Fallback pizza because menu-service is unavailable");
        response.setPrice(299.0);
        response.setAvailable(true);
        response.setVeg(true);
        response.setPreparationTimeMinutes(20);
        return response;
    }
}
