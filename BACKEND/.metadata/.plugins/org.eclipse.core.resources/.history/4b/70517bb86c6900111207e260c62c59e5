        assertNotNull(responses);
        assertEquals(3, responses.size());

        assertEquals(1L, responses.get(0).getOrderId());
        assertEquals(947.0, responses.get(0).getTotalAmount());
        assertEquals(OrderStatus.DELIVERED, responses.get(0).getOrderStatus());

        assertEquals(2L, responses.get(1).getOrderId());
        assertEquals(OrderStatus.CANCELLED, responses.get(1).getOrderStatus());

        assertEquals(3L, responses.get(2).getOrderId());
        assertEquals(OrderStatus.ASSIGNED, responses.get(2).getOrderStatus());

        verify(customerOrderRepository, times(1)).findAll();
    }

    @Test
    void getAnalyticsShouldReturnBusinessAnalytics() {

        when(customerOrderRepository.findAll())
                .thenReturn(List.of(deliveredOrder, cancelledOrder, assignedOrder));

        when(menuClient.getPizzaById(1L)).thenReturn(farmhousePizzaResponse);
        when(menuClient.getPizzaById(2L)).thenReturn(margheritaPizzaResponse);
        when(menuClient.getPizzaById(3L)).thenReturn(cheeseBurstPizzaResponse);

        when(deliveryTrackingRepository.countByDeliveryStatusNot(DeliveryStatus.DELIVERED))
                .thenReturn(1L);

        AdminAnalyticsResponse response = adminService.getAnalytics();

        assertNotNull(response);

        /*
         * Cancelled order is skipped for revenue and items.
         * Delivered items: Farmhouse qty 2, Margherita qty 1
         * Assigned items: Cheese Burst qty 3
         * Total items = 6
         */
        assertEquals(6, response.getTotalItemsSold());

        /*
         * Base revenue excludes cancelled:
         * 947 + 1197 = 2144
         */
        assertEquals(2144.0, response.getBaseRevenue());

        /*
         * GST = 2144 * 5% = 107.2
         */
        assertEquals(107.2, response.getGstCollected());

        /*
         * Final revenue = 2144 + 107.2 = 2251.2
         */
        assertEquals(2251.2, response.getFinalRevenueWithGst());

        /*
         * Average order value = final revenue / non-cancelled orders
         * 2251.2 / 2 = 1125.6
         */
        assertEquals(1125.6, response.getAverageOrderValue());

        assertEquals(1L, response.getActiveDeliveryCount());

        assertNotNull(response.getOrderStatusCounts());
        assertEquals(1L, response.getOrderStatusCounts().get("DELIVERED"));
        assertEquals(1L, response.getOrderStatusCounts().get("CANCELLED"));
        assertEquals(1L, response.getOrderStatusCounts().get("ASSIGNED"));

        assertNotNull(response.getTopSellingPizzas());
        assertEquals(3, response.getTopSellingPizzas().size());

        TopSellingPizzaResponse firstPizza = response.getTopSellingPizzas().get(0);
        assertEquals(3L, firstPizza.getPizzaId());
        assertEquals("Cheese Burst Pizza", firstPizza.getPizzaName());
        assertEquals(3, firstPizza.getQuantitySold());

        /*
         * Cheese Burst revenue with GST:
         * 1197 + 5% = 1256.85
         */
        assertEquals(1256.85, firstPizza.getRevenue());

        TopSellingPizzaResponse secondPizza = response.getTopSellingPizzas().get(1);
        assertEquals(1L, secondPizza.getPizzaId());
        assertEquals("Farmhouse Pizza", secondPizza.getPizzaName());
        assertEquals(2, secondPizza.getQuantitySold());

        TopSellingPizzaResponse thirdPizza = response.getTopSellingPizzas().get(2);
        assertEquals(2L, thirdPizza.getPizzaId());
        assertEquals("Margherita Pizza", thirdPizza.getPizzaName());
        assertEquals(1, thirdPizza.getQuantitySold());

        assertNotNull(response.getCategoryRevenue());
        assertEquals(2, response.getCategoryRevenue().size());

        CategoryRevenueResponse firstCategory = response.getCategoryRevenue().get(0);
        assertEquals("Cheese Pizza", firstCategory.getCategoryName());
        assertEquals(1256.85, firstCategory.getRevenue());

        CategoryRevenueResponse secondCategory = response.getCategoryRevenue().get(1);
        assertEquals("Veg Pizza", secondCategory.getCategoryName());

        /*
         * Veg Pizza revenue with GST:
         * Farmhouse 698 + GST 34.9 = 732.9
         * Margherita 249 + GST 12.45 = 261.45
         * Total = 994.35
         */
        assertEquals(994.35, secondCategory.getRevenue());

        verify(customerOrderRepository, times(1)).findAll();
        verify(menuClient, times(1)).getPizzaById(1L);
        verify(menuClient, times(1)).getPizzaById(2L);
        verify(menuClient, times(1)).getPizzaById(3L);
        verify(deliveryTrackingRepository, times(1))
                .countByDeliveryStatusNot(DeliveryStatus.DELIVERED);
    }

