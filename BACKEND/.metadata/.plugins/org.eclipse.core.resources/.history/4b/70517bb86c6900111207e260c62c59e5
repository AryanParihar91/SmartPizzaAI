    @Test
    void getDashboardShouldReturnDashboardDataWithGstRevenue() {

        when(customerOrderRepository.findAll())
                .thenReturn(List.of(deliveredOrder, cancelledOrder, assignedOrder));

        when(customerOrderRepository.countByOrderStatus(OrderStatus.DELIVERED))
                .thenReturn(1L);

        when(customerOrderRepository.countByOrderStatus(OrderStatus.CANCELLED))
                .thenReturn(1L);

        AdminDashboardResponse response = adminService.getDashboard();

        assertNotNull(response);

        assertEquals(3L, response.getTotalOrders());

        /*
         * Cancelled order is excluded.
         * Delivered order = 947 + 5% GST = 994.35
         * Assigned order = 1197 + 5% GST = 1256.85
         * Total revenue = 2251.20
         */
        assertEquals(2251.20, response.getTotalRevenue());

        assertEquals(1L, response.getDeliveredOrders());
        assertEquals(1L, response.getCancelledOrders());
        assertEquals(1L, response.getActiveOrders());

        verify(customerOrderRepository, times(1)).findAll();
        verify(customerOrderRepository, times(1)).countByOrderStatus(OrderStatus.DELIVERED);
        verify(customerOrderRepository, times(1)).countByOrderStatus(OrderStatus.CANCELLED);
    }

