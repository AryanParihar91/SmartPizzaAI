spring.application.name=api-gateway

server.port=8080

# Eureka Client Config
eureka.client.service-url.defaultZone=http://localhost:8761/eureka/
eureka.client.register-with-eureka=true
eureka.client.fetch-registry=true

# Using the service name from Eureka
spring.cloud.gateway.server.webflux.discovery.locator.enabled=true
spring.cloud.gateway.server.webflux.discovery.locator.lower-case-service-id=true

# Gateway Routes

# Auth Service
spring.cloud.gateway.server.webflux.routes[0].id=auth-service
spring.cloud.gateway.server.webflux.routes[0].uri=lb://auth-service
spring.cloud.gateway.server.webflux.routes[0].predicates[0]=Path=/api/auth/**

# Menu Service
spring.cloud.gateway.server.webflux.routes[1].id=menu-service
spring.cloud.gateway.server.webflux.routes[1].uri=lb://menu-service
spring.cloud.gateway.server.webflux.routes[1].predicates[0]=Path=/api/menu/**

# Order Service - Orders
spring.cloud.gateway.server.webflux.routes[2].id=order-service-orders
spring.cloud.gateway.server.webflux.routes[2].uri=lb://order-service
spring.cloud.gateway.server.webflux.routes[2].predicates[0]=Path=/api/orders/**

# Order Service - Cart
spring.cloud.gateway.server.webflux.routes[3].id=order-service-cart
spring.cloud.gateway.server.webflux.routes[3].uri=lb://order-service
spring.cloud.gateway.server.webflux.routes[3].predicates[0]=Path=/api/cart/**

# Order Service - Coupons
spring.cloud.gateway.server.webflux.routes[4].id=order-service-coupons
spring.cloud.gateway.server.webflux.routes[4].uri=lb://order-service
spring.cloud.gateway.server.webflux.routes[4].predicates[0]=Path=/api/coupons/**

# Order Service - Delivery
spring.cloud.gateway.server.webflux.routes[5].id=order-service-delivery
spring.cloud.gateway.server.webflux.routes[5].uri=lb://order-service
spring.cloud.gateway.server.webflux.routes[5].predicates[0]=Path=/api/delivery/**

# Order Service - Admin
spring.cloud.gateway.server.webflux.routes[6].id=order-service-admin
spring.cloud.gateway.server.webflux.routes[6].uri=lb://order-service
spring.cloud.gateway.server.webflux.routes[6].predicates[0]=Path=/api/admin/**

# Recommendation Service
spring.cloud.gateway.server.webflux.routes[7].id=recommendation-service
spring.cloud.gateway.server.webflux.routes[7].uri=lb://recommendation-service
spring.cloud.gateway.server.webflux.routes[7].predicates[0]=Path=/api/recommendations/**

# Payment Service - Payments
spring.cloud.gateway.server.webflux.routes[8].id=payment-service-payments
spring.cloud.gateway.server.webflux.routes[8].uri=lb://payment-service
spring.cloud.gateway.server.webflux.routes[8].predicates[0]=Path=/api/payments/**

# Payment Service - Invoices
spring.cloud.gateway.server.webflux.routes[9].id=payment-service-invoices
spring.cloud.gateway.server.webflux.routes[9].uri=lb://payment-service
spring.cloud.gateway.server.webflux.routes[9].predicates[0]=Path=/api/invoices/**

# Actuator
management.endpoints.web.exposure.include=health,info,gateway
management.endpoint.health.show-details=always