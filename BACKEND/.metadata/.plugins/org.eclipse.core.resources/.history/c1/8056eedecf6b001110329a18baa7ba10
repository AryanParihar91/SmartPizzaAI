spring.application.name=recommendation-service

server.port=8084

# MySQL Config
spring.datasource.url=jdbc:mysql://localhost:3308/smartpizza_recommendation_db
spring.datasource.username=root
spring.datasource.password=root123

# JPA Config
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# Eureka Config
eureka.client.service-url.defaultZone=http://localhost:8761/eureka/
eureka.client.register-with-eureka=true
eureka.client.fetch-registry=true

# Eureka Instance Config
eureka.instance.hostname=localhost
eureka.instance.prefer-ip-address=false
eureka.instance.instance-id=${spring.application.name}:${server.port}
eureka.instance.non-secure-port=${server.port}
eureka.instance.home-page-url=http://localhost:${server.port}/
eureka.instance.status-page-url=http://localhost:${server.port}/actuator/info
eureka.instance.health-check-url=http://localhost:${server.port}/actuator/health

# Actuator
management.endpoints.web.exposure.include=health,info
management.endpoint.health.show-details=always

#Logger Config
logging.file.name=logs/recommendation-service.log

logging.level.root=INFO
logging.level.com.smartpizza.recommendationservice=INFO
logging.level.org.springframework.web=INFO
logging.level.org.hibernate.SQL=WARN

logging.pattern.console=%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%logger{36}] - %msg%n
logging.pattern.file=%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%logger{36}] - %msg%n
